# Database Configuration
DB_URL=jdbc:postgresql://your-host:port/database?sslmode=require
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# OpenSearch Configuration (uses AWS credentials for authentication)
OPENSEARCH_ENABLED=true
OPENSEARCH_HOST=your-opensearch-host.es.amazonaws.com
OPENSEARCH_PORT=443

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRATION=3600000
PASSWORD_RESET_MAX_ATTEMPTS=3
PASSWORD_RESET_LOCKOUT_DURATION=900000

# Frontend URL
FRONTEND_URL=http://localhost:5177

# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS Cognito Configuration
AWS_COGNITO_REGION=eu-central-1
AWS_COGNITO_USER_POOL_ID=your_user_pool_id
AWS_COGNITO_CLIENT_ID=your_client_id

# AWS Content Moderation Configuration (Rekognition & Comprehend)
AWS_MODERATION_REGION=eu-central-1
AWS_MODERATION_ENABLED=true
AWS_REKOGNITION_MIN_CONFIDENCE=75.0
AWS_COMPREHEND_MIN_CONFIDENCE=0.7
